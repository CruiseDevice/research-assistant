# --- LLM configuration ---
# Provider to use: "anthropic" or "openai"
LLM_PROVIDER=openai
# Model name for the selected provider
LLM_MODEL=gpt-4o

# --- LLM provider API keys ---
# Used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=

# --- Search configuration ---
# Search backend: "tavily" (default)
SEARCH_PROVIDER=tavily
# Used when SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
